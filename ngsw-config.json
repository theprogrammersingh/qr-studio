{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.svg",
          "/icons/*.svg",
          "/icons/*.png",
          "/manifest.webmanifest",
          "/index.html",
          "/index.csr.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "static",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**", "/og-image.svg", "/robots.txt"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "fonts",
      "urls": ["https://fonts.googleapis.com/**", "https://fonts.gstatic.com/**"],
      "cacheConfig": { "strategy": "freshness", "maxSize": 30, "maxAge": "30d", "timeout": "3s" }
    }
  ]
}
